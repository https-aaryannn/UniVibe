rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Votes collection rules
    match /votes/{emailId} {
      // Anyone can read the total vote counts (needed for leaderboard)
      allow read: if true;
      
      // A user can create a vote ONLY IF:
      // 1. the document name (emailId) matches what's in the data body payload
      // 2. they aren't overwriting an existing vote (vote once)
      // 3. they specify an instagram username or the votes array
      allow create: if request.auth != null 
                   && request.auth.token.email == emailId
                   && request.resource.data.email == emailId
                   && !exists(/databases/$(database)/documents/votes/$(emailId))
                   && (request.resource.data.keys().hasAll(['email', 'instagram_username', 'created_at']) ||
                       request.resource.data.keys().hasAll(['email', 'votes', 'created_at']));
      
      // Allow users to update their own votes.
      // Note: Because the Admin dashboard uses hardcoded frontend credentials rather than Firebase Auth,
      // restricting 'update' will cause the Admin 'Delete' button to fail when removing a candidate
      // from a generic user's document. To fix this fully, you should transition Admin to use Firebase Auth.
      allow update: if request.auth != null 
                   && request.auth.token.email == emailId
                   && request.resource.data.email == emailId;
                   
      // Leaving delete broad for the non-authenticated Admin dashboard delete functionality
      allow delete: if true;
    }

    // Settings collection rules
    match /settings/{docId} {
      // Anyone can read if results are published
      allow read: if true;
      // Anyone can update setting (since we use env variables instead of Firebase Auth for now)
      allow write: if true;
    }
  }
}
